{
  "name": "sounduncloud",
  "private": true,
  "version": "0.6.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "auth:dev": "cargo run --manifest-path auth-service/Cargo.toml",
    "auth:check": "cargo check --manifest-path auth-service/Cargo.toml",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:latest-json": "powershell -ExecutionPolicy Bypass -File scripts/write-latest-json.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
